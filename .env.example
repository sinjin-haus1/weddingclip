# WeddingClip Environment Variables
PORT=4000
MONGODB_URI=mongodb://localhost:27017/weddingclip
FRONTEND_URL=http://localhost:3000

# Google Places API (for fetching reviews)
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# TikTok Content Posting API
TIKTOK_CLIENT_ID=your_tiktok_client_id
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:4000/auth/tiktok/callback

# Instagram Graph API
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
INSTAGRAM_REDIRECT_URI=http://localhost:4000/auth/instagram/callback

# Google OAuth (YouTube)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ElevenLabs TTS (optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
